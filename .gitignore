# ==========================================
# 1. Credentials & Secrets
# ==========================================
# CRITICAL: Never commit your secret environment variables
.env
.env.*
*.pem
*.key

# ==========================================
# 2. Compiled Go Binaries & Build Artifacts
# ==========================================
# Specific Makefile outputs
/*-binary

# Standalone Go binaries at the root only (prevents ignoring cmd/ folders!)
/fleet
/telemetry
/leaderboard
/sandbox
/mock_contestant
/bot

# General Go testing and build files
*.out
*.test
*.prof
*.exe
/bin/
/build/

# ==========================================
# 3. Local Data & Volumes
# ==========================================
# Ignore local database data generated by docker-compose
/volumes/
/redpanda_data/
/timescaledb_data/
/postgres_data/

# ==========================================
# 4. Kubernetes & Docker Overrides
# ==========================================
/k8s-override/
docker-compose.override.yml

# ==========================================
# 5. OS & IDE Junk
# ==========================================
.DS_Store
.AppleDouble
.LSOverride
Icon
._*
.Spotlight-V100
.Trashes

# IDEs
.vscode/
.idea/
*.swp
*.swo
terraform/.terraform/
terraform/*.tfstate
terraform/*.tfstate.*